DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_FALLBACK_MODELS=qwen-turbo,qwen-turbo-latest,qwen-flash,qwen-long
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_MODEL=gpt-5.4
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ifome_rag
# Optional fallback provider
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
ENABLE_LIVE_LLM=false
ENABLE_LIVE_RAG=false
ENABLE_OPENAI_ROUTING=false
LLM_REQUEST_TIMEOUT_SECONDS=30
RAG_QUERY_LIMIT=8
RAG_RERANK_LIMIT=4
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
ENABLE_PROJECT_SELF_MEMORY=false
